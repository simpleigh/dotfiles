##
# minikube quickly sets up a local Kubernetes cluster
#
# Installation:
#     curl --fail https://github.com/kubernetes/minikube/releases/latest/download/minikube-linux-amd64 > minikube
#     sudo install --target-directory /usr/local/bin/ minikube
#
# @see https://minikube.sigs.k8s.io/docs/start/
##

if [[ -n $(which minikube) ]]; then
    ##
    # bash auto-completion
    #
    # @see https://minikube.sigs.k8s.io/docs/commands/completion/
    ##
    source <(minikube completion bash)
fi
