##
# CLI for HashiCorp Terraform
#
# Installation:
#     curl --fail https://apt.releases.hashicorp.com/gpg | gpg --dearmor | sudo tee /etc/apt/keyrings/hashicorp-archive-keyring.gpg > /dev/null
#     echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release --codename --short) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list
#     sudo apt-get update
#     sudo apt-get install terraform
#
# @see https://developer.hashicorp.com/terraform/tutorials/aws-get-started/install-cli
##

if [[ -n $(which terraform) ]]; then
    ##
    # bash auto-completion
    ##
    complete -C /usr/bin/terraform terraform
fi
