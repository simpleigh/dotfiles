##
# The package manager for Kubernetes
#
# Installation:
#     curl --fail --location https://packages.buildkite.com/helm-linux/helm-debian/gpgkey | gpg --dearmor | sudo tee /etc/apt/keyrings/helm.gpg > /dev/null
#     echo "deb [signed-by=/etc/apt/keyrings/helm.gpg] https://packages.buildkite.com/helm-linux/helm-debian/any/ any main" | sudo tee /etc/apt/sources.list.d/helm-stable-debian.list
#     sudo apt-get update
#     sudo apt-get install helm
#
# @see https://helm.sh/docs/intro/install/#from-apt-debianubuntu
##

if [[ -n $(which helm) ]]; then
    ##
    # bash auto-completion
    #
    # @see https://helm.sh/docs/helm/helm_completion_bash/
    ##
    source <(helm completion bash)
fi
