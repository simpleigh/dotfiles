##
# Skaffold is a command line tool that facilitates continuous development for
# Kubernetes-native applications
#
# Installation:
#     curl --fail https://storage.googleapis.com/skaffold/releases/latest/skaffold-linux-amd64 > skaffold
#     sudo install --target-directory /usr/local/bin/ skaffold
#
# @see https://skaffold.dev/docs/install/
##

if [[ -n $(which skaffold) ]]; then
    ##
    # bash auto-completion
    #
    # @see https://skaffold.dev/docs/references/cli/#skaffold-completion
    ##
    source <(skaffold completion bash)
fi
